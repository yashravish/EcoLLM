# ─── EcoLLM Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values before running `make dev`.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── API Service ──────────────────────────────────────────────────────────────

# TCP port the Fiber HTTP server listens on
PORT=8080

# PostgreSQL connection string
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://ecollm:ecollm_dev@localhost:5432/ecollm?sslmode=disable

# Redis connection string
REDIS_URL=redis://localhost:6379

# Secret used to sign JWT tokens — use `openssl rand -hex 32` to generate
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# Comma-separated list of allowed CORS origins
# Example: https://app.ecollm.io,https://staging.ecollm.io
ALLOWED_ORIGINS=http://localhost:3000

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# ─── Rate Limiting ────────────────────────────────────────────────────────────

# Default requests per minute per API key (org-level overrides stored in DB)
RATE_LIMIT_PER_MINUTE=60

# Maximum allowed duration for a single inference request
REQUEST_TIMEOUT=30s

# ─── Inference Gateway ────────────────────────────────────────────────────────

# vLLM / Ollama endpoint URLs per model tier
# In Docker Compose dev: use service names (http://inference-gateway:8090/...)
# In GPU mode: point directly at vLLM containers
INFERENCE_PHI3_URL=http://localhost:8090/phi3
INFERENCE_MISTRAL_URL=http://localhost:8090/mistral
INFERENCE_LLAMA13B_URL=http://localhost:8090/llama13b
INFERENCE_LLAMA70B_URL=http://localhost:8090/llama70b

# ─── Prompt Optimizer (Phi-3 sidecar) ────────────────────────────────────────

# Base URL for the Python prompt-optimizer microservice
PHI3_SIDECAR_URL=http://localhost:8000

# Feature flag: enable/disable prompt optimization pass before routing
ENABLE_PROMPT_OPTIMIZATION=false

# ─── Carbon Tracking ─────────────────────────────────────────────────────────

# Enable per-request CO2e estimation and persistence
ENABLE_CARBON_TRACKING=true

# Grid region for carbon intensity lookup.
# Supported: US-EAST, US-WEST, EU-WEST, EU-NO, EU-DE, APAC-SG, COAL, HYDRO
# Falls back to US average (450 gCO2/kWh) if region not found.
GRID_REGION=US-EAST

# Electricity Maps API key (optional — used for real-time grid intensity).
# If empty, static regional averages from AGENT_KNOWLEDGE_BASE Layer 6 are used.
GRID_API_KEY=

# ─── Caching ─────────────────────────────────────────────────────────────────

# Enable Redis prompt response cache (SHA-256 keyed, 1h TTL)
ENABLE_CACHE=true

# ─── Fallback Routing ─────────────────────────────────────────────────────────

# Enable automatic fallback chain: phi_3 → mistral_7b → llama_13b → llama_70b
ENABLE_FALLBACK=true

# ─── Inference Gateway Service ────────────────────────────────────────────────

# Port the inference-gateway binary listens on
INFERENCE_GATEWAY_PORT=8090

# Ollama base URL (used in CPU/dev mode)
OLLAMA_BASE_URL=http://localhost:11434

# ─── Carbon Service ───────────────────────────────────────────────────────────

# Port the carbon-service binary listens on
CARBON_SERVICE_PORT=8091

# ─── OpenTelemetry ────────────────────────────────────────────────────────────

# OTLP collector endpoint for traces and metrics
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service name reported to tracing backend
OTEL_SERVICE_NAME=ecollm-api

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────

# API base URL consumed by the browser — must be publicly reachable
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Database Migrations ──────────────────────────────────────────────────────

# Used by the `make migrate` target and the golang-migrate CLI
# Defaults to DATABASE_URL if not set separately
MIGRATE_DATABASE_URL=postgres://ecollm:ecollm_dev@localhost:5432/ecollm?sslmode=disable

# ─── Grafana (local only) ─────────────────────────────────────────────────────

# Default admin password for the local Grafana instance (change before exposing publicly)
GF_SECURITY_ADMIN_PASSWORD=admin
